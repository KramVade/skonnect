<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Page {{number}} — Stages of Love</title>

  <!-- Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- DataTables -->
  <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css">
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>

  <style>
    /* Custom scrollbar & transitions */
    ::-webkit-scrollbar {
      width: 8px;
    }
    ::-webkit-scrollbar-thumb {
      background: rgba(120, 40, 60, 0.3);
      border-radius: 4px;
    }
    body {
      font-family: 'Inter', sans-serif;
    }
    table.dataTable thead th {
      background: rgba(255, 255, 255, 0.3);
      backdrop-filter: blur(4px);
    }
    .fade-in {
      animation: fadeIn 0.6s ease forwards;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>

<body class="bg-gradient-to-br from-rose-100 via-pink-50 to-rose-200 min-h-screen flex flex-col">

  <!-- Header -->
  <header class="bg-rose-800 text-white shadow-lg">
    <div class="container mx-auto flex justify-between items-center py-4 px-6">
      <div class="text-2xl font-bold tracking-wide">💌 MyBrand</div>
      <span class="italic text-rose-200">Stages of Love</span>
    </div>
  </header>

  <!-- Main -->
  <main class="container mx-auto px-6 py-10 flex-1 fade-in">
    <div class="text-center mb-10">
      <h1 class="text-4xl font-extrabold text-rose-900 mb-2">Page {{number}}</h1>
      <p class="text-rose-700 italic">“Every heart breaks differently — and heals slower than time dares to admit.”</p>
    </div>

    <!-- DataTable -->
    <div class="bg-white bg-opacity-70 backdrop-blur-md shadow-lg rounded-xl p-6 overflow-x-auto">
      <table id="stagesTable" class="display w-full">
        <thead>
          <tr class="text-rose-900">
            <th>#</th>
            <th>Stage of Love</th>
            <th>Description</th>
            <th>View</th>
            <th>Edit</th>
            <th>Delete</th>
          </tr>
        </thead>
        <tbody>
          {{#each stages}}
          <tr class="hover:bg-rose-50 transition">
            <td>{{@index}}</td>
            <td class="font-semibold text-rose-800">{{this.name}}</td>
            <td class="text-gray-600">{{this.description}}</td>
            <td>
              <button class="text-blue-600 hover:underline view-btn" 
                data-name="{{this.name}}" data-description="{{this.description}}">
                View
              </button>
            </td>
            <td>
              <button class="text-green-600 hover:underline edit-btn" 
                data-index="{{@index}}" data-name="{{this.name}}" data-description="{{this.description}}">
                Edit
              </button>
            </td>
            <td>
              <button class="text-red-600 hover:underline delete-btn" 
                data-index="{{@index}}" data-name="{{this.name}}">
                Delete
              </button>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>

    <div class="text-center mt-8">
      <a href="/dashboard.xian"
        class="bg-rose-700 hover:bg-rose-800 text-white px-5 py-2 rounded-lg shadow-md transition-colors inline-block">
        ← Back to Dashboard
      </a>
    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-rose-900 text-white mt-12">
    <div class="container mx-auto px-6 py-6 text-center">
      <p class="text-rose-200 text-sm">&copy; 2025 MyBrand. All rights reserved.</p>
    </div>
  </footer>

  <!-- View Modal -->
  <div id="stageModal"
    class="fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-2xl shadow-2xl p-8 w-full max-w-md text-center fade-in">
      <h2 id="modalStageName" class="text-2xl font-bold mb-4 text-rose-900">Stage of Love</h2>
      <p id="modalStageDescription" class="mb-6 text-gray-700 italic"></p>
      <button id="closeModalBtn"
        class="bg-rose-700 text-white px-5 py-2 rounded-lg hover:bg-rose-800">Close</button>
    </div>
  </div>

  <!-- Edit Modal -->
  <div id="editModal"
    class="fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-2xl shadow-2xl p-8 w-full max-w-md text-center fade-in">
      <h2 class="text-2xl font-bold mb-4 text-rose-900">Edit Stage</h2>
      <form id="editForm">
        <input type="hidden" id="editIndex">
        <input type="text" id="editStageNameInput" class="border px-3 py-2 rounded w-full mb-4 focus:ring-2 focus:ring-rose-400" placeholder="Stage Name" />
        <textarea id="editStageDescriptionInput" class="border px-3 py-2 rounded w-full mb-4 focus:ring-2 focus:ring-rose-400" placeholder="Description"></textarea>
        <div class="space-x-2">
          <button type="submit" class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700">Save</button>
          <button type="button" id="closeEditBtn" class="bg-gray-400 text-white px-4 py-2 rounded hover:bg-gray-500">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Delete Modal -->
  <div id="deleteModal"
    class="fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-2xl shadow-2xl p-8 w-full max-w-md text-center fade-in">
      <h2 class="text-2xl font-bold mb-4 text-red-700">Delete Stage</h2>
      <p id="deleteStageText" class="mb-6 text-gray-700"></p>
      <div class="space-x-2">
        <button id="confirmDeleteBtn" class="bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700">Delete</button>
        <button id="closeDeleteBtn" class="bg-gray-400 text-white px-4 py-2 rounded hover:bg-gray-500">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Script -->
  <script>
    $(document).ready(function () {
      $('#stagesTable').DataTable();

      // View Modal
      const modal = $('#stageModal');
      $(document).on('click', '.view-btn', function () {
        $('#modalStageName').text($(this).data('name'));
        $('#modalStageDescription').text($(this).data('description'));
        modal.removeClass('hidden');
      });
      $('#closeModalBtn').click(() => modal.addClass('hidden'));
      modal.click(e => { if (e.target === modal[0]) modal.addClass('hidden'); });

      // Edit Modal
      const editModal = $('#editModal');
      $(document).on('click', '.edit-btn', function () {
        $('#editStageNameInput').val($(this).data('name'));
        $('#editStageDescriptionInput').val($(this).data('description'));
        $('#editIndex').val($(this).data('index'));
        editModal.removeClass('hidden');
      });
      $('#closeEditBtn').click(() => editModal.addClass('hidden'));
      editModal.click(e => { if (e.target === editModal[0]) editModal.addClass('hidden'); });
      $('#editForm').submit(e => {
        e.preventDefault();
        editModal.addClass('hidden');
        alert('Stage updated: ' + $('#editStageNameInput').val());
      });

      // Delete Modal
      const deleteModal = $('#deleteModal');
      let deleteIndex = null;
      $(document).on('click', '.delete-btn', function () {
        $('#deleteStageText').text('Are you sure you want to delete "' + $(this).data('name') + '"?');
        deleteIndex = $(this).data('index');
        deleteModal.removeClass('hidden');
      });
      $('#closeDeleteBtn').click(() => deleteModal.addClass('hidden'));
      deleteModal.click(e => { if (e.target === deleteModal[0]) deleteModal.addClass('hidden'); });
      $('#confirmDeleteBtn').click(() => {
        deleteModal.addClass('hidden');
        alert('Stage deleted at index: ' + deleteIndex);
      });
    });
  </script>
</body>
</html>
