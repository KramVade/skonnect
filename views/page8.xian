<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <title>Page {{number}}</title>
</head>
<body class="bg-gray-100 min-h-screen flex flex-col">

  <header class="bg-gray-900 text-white shadow-md">
    <div class="container mx-auto flex justify-between items-center py-4 px-6">
      <div class="text-2xl font-bold">MyBrand</div>
    </div>
  </header>

  <main class="container mx-auto px-6 py-8 flex-1">
    <h1 class="text-3xl font-bold mb-4">Page {{number}}</h1>
    <p class="mb-6">This is page {{number}}. All roads lead back home eventually.</p>
    <a href="home.xian" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded transition-colors">
      ← Back to Home
    </a>
  </main>

  <footer class="bg-gray-900 text-white mt-12">
    <div class="container mx-auto px-6 py-8 text-center">
      <p class="text-gray-400 text-sm">&copy; 2025 MyBrand. All rights reserved.</p>
    </div>
  </footer>

</body>
</html>
